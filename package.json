{
  "name": "browser-portal",
  "private": true,
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tarik02/portal.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "qg": "turbo run format lint ast-grep test typecheck build --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "vp lint",
    "ast-grep": "ast-grep scan",
    "format": "vp format --check",
    "typecheck": "tsc -b tsconfig.json",
    "release": "release-it",
    "knip": "knip",
    "check": "vp check && yarn ast-grep",
    "fix": "vp check --fix"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.1",
    "@release-it-plugins/workspaces": "^5.0.3",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "release-it": "^19.2.4",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16",
    "zod": "^4.3.6"
  }
}
