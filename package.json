{
  "name": "browser-portal",
  "private": true,
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tarik02/portal.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "qg": "turbo run format lint ast-grep test typecheck build --parallel",
    "build": "turbo run build",
    "build:publishable": "turbo run build --filter=@tarik02/portal-core --filter=@tarik02/portal-client --filter=@tarik02/portal-server",
    "publish:packages": "yarn workspaces foreach -At --include @tarik02/portal-core --include @tarik02/portal-client --include @tarik02/portal-server npm publish --access public --tolerate-republish",
    "publish:packages:dry-run": "yarn workspaces foreach -At --include @tarik02/portal-core --include @tarik02/portal-client --include @tarik02/portal-server npm publish --access public --dry-run",
    "test": "turbo run test",
    "lint": "vp lint",
    "ast-grep": "ast-grep scan",
    "format": "vp fmt --check",
    "typecheck": "yarn build:publishable && tsc -b tsconfig.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "yarn build:publishable && yarn publish:packages",
    "release:dry-run": "yarn build:publishable && yarn publish:packages:dry-run",
    "knip": "knip",
    "fix": "vp check --fix"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.1",
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  }
}
