{
  "name": "browser-portal",
  "private": true,
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tarik02/portal.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "qg": "yarn check && yarn test && yarn build",
    "build": "turbo run build",
    "check": "yarn format && yarn lint && yarn ast-grep && yarn typecheck && yarn knip",
    "clean": "turbo run clean && rm -rf .turbo",
    "test": "turbo run test",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "ast-grep": "ast-grep scan",
    "ast-grep:fix": "node ./scripts/ast-grep-fix.mjs",
    "format": "vp fmt --check",
    "format:fix": "vp fmt --write",
    "typecheck": "tsc -b",
    "changeset": "changeset",
    "release:publish": "yarn workspaces foreach -At --no-private npm publish --access public --tolerate-republish",
    "release:publish:dry-run": "yarn workspaces foreach -At --no-private npm publish --access public --dry-run",
    "knip": "knip",
    "fix": "yarn ast-grep:fix && yarn lint:fix && yarn format:fix"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.1",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  }
}
