{
  "$schema": "node_modules/release-it/schema/release-it.json",
  "npm": false,
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits"
      },
      "infile": false
    },
    "@release-it-plugins/workspaces": {
      "workspaces": ["packages/portal-core", "packages/portal-client", "packages/portal-server"],
      "publishCommand": "node scripts/publish-workspace.ts"
    }
  }
}
