{
  "compilerOptions": {
    "paths": {
      "@tarik02/portal-core": ["./packages/portal-core/src/index.ts"],
      "@tarik02/portal-client": ["./packages/portal-client/src/index.ts"],
      "@tarik02/portal-server": ["./packages/portal-server/src/index.ts"],
      "@tarik02/portal-example-common": ["./packages/portal-example-common/src/index.ts"],
      "@tarik02/portal-example-common/*": ["./packages/portal-example-common/src/*.ts"]
    },
    "skipLibCheck": true,
    "target": "ESNext",
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,

    "strict": true,
    "noPropertyAccessFromIndexSignature": false,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "module": "ESNext",

    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"]
  }
}
